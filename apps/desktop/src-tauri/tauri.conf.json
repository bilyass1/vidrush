{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VidRush",
  "version": "1.0.0",
  "identifier": "com.vidrush.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../web/.next"
  },
  "app": {
    "windows": [
      {
        "title": "VidRush",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "capabilities": []
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=",
      "endpoints": [
        "https://vidrush.com/releases/{{target}}/{{arch}}/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
